# --- Core ---
PROJECT_NAME=PromptForge
ENVIRONMENT=local
DEBUG=true

# --- Security (generate with: openssl rand -hex 32) ---
SECRET_KEY=CHANGE_ME_dev_secret_key_do_not_use_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
# Leave DATABASE_URL blank to use local SQLite (zero setup).
# For PostgreSQL use:
# DATABASE_URL=postgresql+asyncpg://promptforge:promptforge@localhost:5432/promptforge
DATABASE_URL=
SQLITE_PATH=./promptforge.db
DB_ECHO=false
AUTO_CREATE_TABLES=true

# --- Cache / Queue ---
REDIS_URL=redis://localhost:6379/0

# --- CORS (comma-separated) ---
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
